{
  "name": "dssoca-docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Documentation site for the dssoca design system (SvelteKit + mdsvex, dogfoods dssoca). Local-only; not published.",
  "scripts": {
    "dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/prismjs": "^1.26.5",
    "mdsvex": "^0.12.6",
    "prism-svelte": "^0.5.0",
    "prismjs": "^1.30.0",
    "sass": "^1.100.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.7"
  }
}
