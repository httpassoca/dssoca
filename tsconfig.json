{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "rewriteRelativeImportExtensions": true,
    "allowJs": true,
    "checkJs": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true
    // module/moduleResolution are inherited from .svelte-kit/tsconfig.json
    // (esnext/bundler) — overriding them with NodeNext broke `$lib` and the
    // extensionless test imports under svelte-check (DS-0076).
  }
}
